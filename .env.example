# Lexware Office API key (required)
# Get from: https://app.lexoffice.de → Settings → API
# Can also be an op:// reference for 1Password CLI
LEXOFFICE_API_KEY=your-api-key-here

# Transport (optional, default: streamable-http)
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Keycloak JWT auth (set KEYCLOAK_ISSUER to enable auth)
# The server validates JWTs issued by Keycloak and advertises
# the Keycloak realm as its authorization server (RFC 9728).
KEYCLOAK_ISSUER=https://auth.cdit-works.de/realms/cdit-mcp
KEYCLOAK_AUDIENCE=mcp-lexoffice

# Public base URL of this server (used in protected resource metadata)
# MCP_AUTH_BASE_URL=https://mcp-lexoffice.cdit-dev.de

# Bearer token API key for Claude Code / n8n (auto-generated on first run if empty)
# LEXOFFICE_MCP_API_KEY=

# Old built-in OAuth provider (removed — now delegated to Keycloak)
# MCP_AUTH_BASE_URL was previously used to enable the built-in OAuth server.
# It is now used only for the protected resource metadata base URL.
